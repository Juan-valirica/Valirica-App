# php -- BEGIN cPanel-generated handler, do not edit
# Set the "alt-php82" package as the default "PHP" programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-alt-php82 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# ── Valírica Blog — URL limpias & SEO ─────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Sitemap XML dinámico
  RewriteRule ^sitemap\.xml$ sitemap.php [L]

  # Blog: listado → /blog o /blog/
  RewriteRule ^blog/?$ blog.php [L,QSA]

  # Blog: artículo individual → /blog/slug-del-articulo
  RewriteRule ^blog/([a-z0-9][a-z0-9-]{0,200})/?$ blog-post.php?slug=$1 [L,QSA]

  # Redirección www → non-www (opcional, ajustar dominio)
  # RewriteCond %{HTTP_HOST} ^www\.valirica\.com$ [NC]
  # RewriteRule ^(.*)$ https://valirica.com/$1 [R=301,L]

  # Forzar HTTPS (descomentar si el servidor tiene SSL)
  # RewriteCond %{HTTPS} off
  # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Cabeceras de seguridad & rendimiento ───────────────────────────────────
<IfModule mod_headers.c>
  # Seguridad
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Cache para assets estáticos del blog
  <FilesMatch "\.(css|js|woff2|woff|ttf|png|jpg|jpeg|svg|ico|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # No cachear HTML/PHP
  <FilesMatch "\.(php|html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Compresión GZIP ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml application/xml
</IfModule>
